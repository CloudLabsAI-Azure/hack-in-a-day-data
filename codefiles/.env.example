# ============================================
# Intelligent Infrastructure Operations Assistant
# ============================================
#
# SETUP INSTRUCTIONS:
# 1. Rename this file to .env
# 2. Fill in your Azure credentials below
# 3. Run: az login
# 4. Run: streamlit run app.py
#
# DO NOT commit real credentials to version control.
# ============================================

# ============================================
# REQUIRED: Microsoft Foundry Agent Configuration
# ============================================

# Agent API Endpoint
# Get from: Microsoft Foundry Portal > Your Project > Overview
# Format: https://your-project.services.ai.azure.com/api/projects/proj-default
AGENT_API_ENDPOINT=<your-foundry-endpoint e.g. https://your-project.services.ai.azure.com/api/projects/proj-default>

# Infrastructure-Metrics-Analyzer Agent ID (starts with "asst_")
# Get from: Microsoft Foundry Portal > Agents > Your Agent > Setup panel
AGENT_ID=<your-agent-id e.g. asst_xxxxxxxxxxxxxxxxxxxx>


# ============================================
# REQUIRED: Log Analytics Workspace
# ============================================

# Workspace ID (GUID format)
# Get from: Azure Portal > Log Analytics Workspace > Overview > Workspace ID
LOG_ANALYTICS_WORKSPACE_ID=<your-workspace-id e.g. xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx>

# ============================================
# OPTIONAL: Event Grid Alerting
# ============================================

# Event Grid Topic Endpoint
# Get from: Azure Portal > Event Grid Topic > Overview > Topic Endpoint
# Format: https://infraops-alerts-topic-XXXXXXX.eastus-1.eventgrid.azure.net/api/events
EVENT_GRID_ENDPOINT=<your-event-grid-endpoint e.g. https://your-topic.eastus-1.eventgrid.azure.net/api/events>

# Event Grid Topic Access Key
# Get from: Azure Portal > Event Grid Topic > Access keys > Key 1
EVENT_GRID_KEY=<your-event-grid-key>
